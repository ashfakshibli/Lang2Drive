{
  "scenarios": [
    {
      "id": "basic_driving",
      "description": "Basic driving scenario with one car on a straight road",
      "keywords": ["basic", "single car", "straight road", "simple driving"],
      "code_template": "spawn_single_vehicle",
      "parameters": {
        "vehicle_count": 1,
        "weather": "clear",
        "camera_mode": "follow_car",
        "speed_multiplier": 1.0
      }
    },
    {
      "id": "rainy_two_cars",
      "description": "Two cars driving in rainy weather with third person camera",
      "keywords": ["two cars", "rainy", "rain", "weather", "third person", "follow"],
      "code_template": "spawn_multiple_vehicles_weather",
      "parameters": {
        "vehicle_count": 2,
        "weather": "rain",
        "camera_mode": "follow_car",
        "speed_multiplier": 1.0,
        "precipitation": 80.0
      }
    },
    {
      "id": "intersection_traffic",
      "description": "Multiple vehicles at an intersection with overhead camera view",
      "keywords": ["intersection", "multiple cars", "overhead", "traffic", "intersection view"],
      "code_template": "spawn_intersection_scenario",
      "parameters": {
        "vehicle_count": 6,
        "weather": "clear",
        "camera_mode": "intersection",
        "speed_multiplier": 1.0
      }
    },
    {
      "id": "night_driving",
      "description": "Night time driving scenario with vehicle lights",
      "keywords": ["night", "dark", "evening", "lights", "headlights"],
      "code_template": "spawn_night_scenario",
      "parameters": {
        "vehicle_count": 3,
        "weather": "clear",
        "camera_mode": "follow_car",
        "speed_multiplier": 0.8,
        "sun_altitude_angle": -10.0
      }
    },
    {
      "id": "heavy_rain_slow",
      "description": "Slow driving in heavy rain with reduced visibility",
      "keywords": ["heavy rain", "slow", "visibility", "storm", "bad weather"],
      "code_template": "spawn_weather_scenario",
      "parameters": {
        "vehicle_count": 4,
        "weather": "heavy_rain",
        "camera_mode": "follow_car",
        "speed_multiplier": 0.6,
        "precipitation": 100.0,
        "fog_density": 30.0
      }
    }
  ],
  "code_templates": {
    "spawn_single_vehicle": {
      "description": "Basic single vehicle spawn",
      "code_snippet": "# Spawn single vehicle\nvehicles_to_spawn = 1\ncamera_mode = 'follow_car'\nweather_clear = True"
    },
    "spawn_multiple_vehicles_weather": {
      "description": "Multiple vehicles with weather conditions",
      "code_snippet": "# Spawn multiple vehicles with weather\nvehicles_to_spawn = {vehicle_count}\ncamera_mode = '{camera_mode}'\nweather_params = {{'precipitation': {precipitation}}}"
    },
    "spawn_intersection_scenario": {
      "description": "Intersection scenario with overhead view",
      "code_snippet": "# Intersection scenario\nvehicles_to_spawn = {vehicle_count}\ncamera_mode = 'intersection'\nuse_traffic_lights = True"
    },
    "spawn_night_scenario": {
      "description": "Night time scenario",
      "code_snippet": "# Night scenario\nvehicles_to_spawn = {vehicle_count}\ncamera_mode = '{camera_mode}'\nlighting_params = {{'sun_altitude_angle': {sun_altitude_angle}}}"
    },
    "spawn_weather_scenario": {
      "description": "Weather scenario with custom conditions",
      "code_snippet": "# Weather scenario\nvehicles_to_spawn = {vehicle_count}\ncamera_mode = '{camera_mode}'\nweather_params = {{'precipitation': {precipitation}, 'fog_density': {fog_density}}}"
    }
  }
}
